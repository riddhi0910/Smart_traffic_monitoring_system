# Environment Variables for Smart Traffic Monitoring System
# Copy this file to .env and update the values

# Flask Configuration
FLASK_ENV=development
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=true

# Model and Video Paths
MODEL_PATH=./95_e/cls_fix_30e/weights/best.pt
VIDEO_SOURCE=./WhatsApp Video 2026-04-08 at 10.31.39 PM.mp4

# YOLO Detection Settings
CONFIDENCE_THRESHOLD=0.45
FRAME_SKIP_RATE=3

# Traffic Density Thresholds
TRAFFIC_LOW_THRESHOLD=2
TRAFFIC_MEDIUM_THRESHOLD=5

# Dashboard Settings
DASHBOARD_REFRESH_INTERVAL=1000